---

<div class="logo" aria-hidden="true">
  <svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg" class="logo-svg">
    <circle cx="20" cy="20" r="6" fill="var(--red)" class="logo-pulse"/>
    <line x1="20" y1="14" x2="20" y2="4" stroke="var(--red)" stroke-width="2.5" stroke-linecap="round"/>
    <circle cx="20" cy="3" r="2.5" stroke="var(--red)" stroke-width="1.5" fill="none"/>
    <line x1="14.5" y1="23" x2="6" y2="33" stroke="var(--red)" stroke-width="2.5" stroke-linecap="round"/>
    <circle cx="5" cy="34" r="2.5" stroke="var(--red)" stroke-width="1.5" fill="none"/>
    <line x1="25.5" y1="23" x2="34" y2="33" stroke="var(--red)" stroke-width="2.5" stroke-linecap="round"/>
    <circle cx="35" cy="34" r="2.5" stroke="var(--red)" stroke-width="1.5" fill="none"/>
    <path d="M26 20 L36 20" stroke="var(--cyan)" stroke-width="1.5" stroke-linecap="round" stroke-dasharray="3 2" opacity="0.5"/>
    <path d="M14 20 L4 20" stroke="var(--cyan)" stroke-width="1.5" stroke-linecap="round" stroke-dasharray="3 2" opacity="0.5"/>
  </svg>
</div>

<style>
  .logo {
    width: 32px;
    height: 32px;
    flex-shrink: 0;
    transition: transform 0.5s ease, filter 0.3s;
  }

  .logo:hover {
    transform: rotate(360deg);
    filter: drop-shadow(0 0 8px var(--glow-color));
  }

  .logo-svg {
    width: 100%;
    height: 100%;
  }

  .logo-pulse {
    animation: logo-pulse-anim 2s ease-in-out infinite;
  }

  @keyframes logo-pulse-anim {
    0%, 100% {
      r: 6;
      opacity: 0.8;
    }
    50% {
      r: 7;
      opacity: 1;
    }
  }
</style>
