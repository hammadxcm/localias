---
const managers = [
  {
    id: 'npm',
    label: 'npm',
    command: 'npm i -g localias',
  },
  {
    id: 'pnpm',
    label: 'pnpm',
    command: 'pnpm add -g localias',
  },
  {
    id: 'yarn',
    label: 'yarn',
    command: 'yarn global add localias',
  },
  {
    id: 'bun',
    label: 'bun',
    command: 'bun add -g localias',
  },
  {
    id: 'homebrew',
    label: 'Homebrew',
    command: 'brew install hammadxcm/localias/localias',
  },
];
---

<section class="section" id="install">
  <div class="container">
    <h2 class="section-title reveal">Install <span class="gradient-text">localias</span></h2>
    <p class="section-subtitle reveal">Global install required — localias runs a background proxy, so npx won't work.</p>
    <div aria-live="polite" class="sr-only" id="copy-status"></div>

    <div class="pm-tabs reveal" role="tablist" aria-label="Package manager">
      {managers.map((pm, i) => (
        <button
          role="tab"
          id={`pm-tab-${pm.id}`}
          class={`pm-tab-btn ${i === 0 ? 'active' : ''}`}
          aria-selected={i === 0 ? 'true' : 'false'}
          aria-controls={`pm-panel-${pm.id}`}
          tabindex={i === 0 ? 0 : -1}
          type="button"
        >
          {pm.label}
        </button>
      ))}
    </div>

    {managers.map((pm, i) => (
      <div
        class={`pm-panel ${i === 0 ? 'active' : ''}`}
        role="tabpanel"
        id={`pm-panel-${pm.id}`}
        aria-labelledby={`pm-tab-${pm.id}`}
        tabindex="0"
      >
        <div class="install-block">
          <div class="install-label">Global Install</div>
          <div class="install-code">
            <code>{pm.command}</code>
            <button class="copy-btn" data-copy={pm.command} aria-label={`Copy ${pm.label} install command`}>
              <span class="copy-icon">&#x2398;</span>
              <span class="copy-check" aria-hidden="true">&#x2713;</span>
            </button>
          </div>
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .pm-tabs {
    display: flex;
    gap: 0;
    margin-bottom: 24px;
    border-bottom: 2px solid var(--border);
  }

  .pm-tab-btn {
    padding: 12px 24px;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text-muted);
    cursor: pointer;
    border: none;
    border-bottom: 2px solid transparent;
    margin-bottom: -2px;
    transition: color 0.2s, border-color 0.2s;
    min-height: 44px;
    display: flex;
    align-items: center;
    background: none;
    font-family: var(--font-sans);
  }

  .pm-tab-btn:hover {
    color: var(--text);
  }

  .pm-tab-btn.active {
    color: var(--red);
    border-bottom-color: var(--red);
  }

  .pm-panel {
    display: none;
  }

  .pm-panel.active {
    display: block;
  }

  .install-block {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 24px;
  }

  .install-label {
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-muted);
    margin-bottom: 12px;
  }

  .install-code {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    background: var(--bg-terminal);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 12px 16px;
    font-family: var(--font-mono);
    font-size: 0.82rem;
    color: var(--green);
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  .install-code code {
    white-space: nowrap;
  }

  .copy-btn {
    flex-shrink: 0;
    background: none;
    border: none;
    color: var(--text-muted);
    cursor: pointer;
    font-size: 1rem;
    padding: 8px;
    border-radius: 4px;
    transition: color 0.2s;
    position: relative;
    min-width: 44px;
    min-height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .copy-btn:hover {
    color: var(--text);
  }

  .copy-check {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--green);
    opacity: 0;
    transition: opacity 0.2s;
  }

  .copy-btn.copied .copy-icon {
    opacity: 0;
  }

  .copy-btn.copied .copy-check {
    opacity: 1;
  }

  @media (max-width: 768px) {
    .pm-tabs {
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
    }

    .pm-tab-btn {
      padding: 10px 16px;
      font-size: 0.8rem;
      white-space: nowrap;
    }

    .install-block {
      padding: 16px;
    }

    .install-code {
      font-size: 0.75rem;
      padding: 10px 12px;
    }
  }

  @media (max-width: 480px) {
    .pm-tab-btn {
      padding: 8px 12px;
      font-size: 0.75rem;
    }

    .install-code code {
      word-break: break-all;
      white-space: normal;
    }
  }
</style>

<script>
  const pmTablist = document.querySelector<HTMLElement>('.pm-tabs[role="tablist"]');
  const pmTabs = Array.from(document.querySelectorAll<HTMLButtonElement>('.pm-tab-btn[role="tab"]'));
  const pmPanels = document.querySelectorAll<HTMLElement>('.pm-panel[role="tabpanel"]');
  const copyStatus = document.getElementById('copy-status');

  function activatePmTab(tab: HTMLButtonElement) {
    pmTabs.forEach((t) => {
      t.setAttribute('aria-selected', 'false');
      t.tabIndex = -1;
      t.classList.remove('active');
    });
    tab.setAttribute('aria-selected', 'true');
    tab.tabIndex = 0;
    tab.classList.add('active');
    tab.focus();

    const targetId = tab.getAttribute('aria-controls');
    pmPanels.forEach((panel) => {
      panel.classList.toggle('active', panel.id === targetId);
    });
  }

  pmTabs.forEach((tab) => {
    tab.addEventListener('click', () => activatePmTab(tab));
  });

  pmTablist?.addEventListener('keydown', (e) => {
    const event = e as KeyboardEvent;
    const current = pmTabs.indexOf(document.activeElement as HTMLButtonElement);
    let next: number | null = null;

    if (event.key === 'ArrowRight') next = (current + 1) % pmTabs.length;
    else if (event.key === 'ArrowLeft') next = (current - 1 + pmTabs.length) % pmTabs.length;
    else if (event.key === 'Home') next = 0;
    else if (event.key === 'End') next = pmTabs.length - 1;

    if (next !== null) {
      event.preventDefault();
      activatePmTab(pmTabs[next]);
    }
  });

  document.querySelectorAll<HTMLButtonElement>('.copy-btn').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const text = btn.dataset.copy;
      if (!text) return;

      await navigator.clipboard.writeText(text);
      btn.classList.add('copied');
      if (copyStatus) {
        copyStatus.textContent = `Copied: ${text}`;
        setTimeout(() => { copyStatus.textContent = ''; }, 1500);
      }
      setTimeout(() => btn.classList.remove('copied'), 1500);
    });
  });
</script>
