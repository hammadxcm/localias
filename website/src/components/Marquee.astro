---
const techs = [
  { name: 'Vite', slug: 'vite', color: '646CFF' },
  { name: 'Astro', slug: 'astro', color: 'BC52EE' },
  { name: 'Angular', slug: 'angular', color: 'DD0031' },
  { name: 'React', slug: 'react', color: '61DAFB' },
  { name: 'Next.js', slug: 'nextdotjs', color: '000000' },
  { name: 'Nuxt', slug: 'nuxtdotjs', color: '00DC82' },
  { name: 'SvelteKit', slug: 'svelte', color: 'FF3E00' },
  { name: 'Docker', slug: 'docker', color: '2496ED' },
  { name: 'Node.js', slug: 'nodedotjs', color: '5FA04E' },
  { name: 'Bun', slug: 'bun', color: 'F9F1E1' },
  { name: 'Expo', slug: 'expo', color: '000020' },
];
---

<div class="marquee" aria-hidden="true">
  <div class="marquee-track">
    {
      [...techs, ...techs].map((tech) => (
        <span class="marquee-item">
          <img
            class="marquee-icon"
            src={`https://cdn.simpleicons.org/${tech.slug}/${tech.color}`}
            alt=""
            width="28"
            height="28"
            loading="lazy"
            decoding="async"
          />
          {tech.name}
        </span>
      ))
    }
  </div>
</div>

<style>
  .marquee {
    overflow: hidden;
    padding: 32px 0;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    mask-image: linear-gradient(90deg, transparent, #000 10%, #000 90%, transparent);
    -webkit-mask-image: linear-gradient(
      90deg,
      transparent,
      #000 10%,
      #000 90%,
      transparent
    );
  }

  .marquee-track {
    display: flex;
    gap: 56px;
    width: max-content;
    animation: marquee-scroll 40s linear infinite;
    will-change: transform;
  }

  .marquee-item {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    font-family: var(--font-mono);
    font-size: 1rem;
    color: var(--text-muted);
    white-space: nowrap;
    font-weight: 500;
    transition: color 0.3s;
  }

  .marquee-item:hover {
    color: var(--text);
  }

  .marquee-item:hover .marquee-icon {
    filter: none;
  }

  .marquee-icon {
    width: 28px;
    height: 28px;
    flex-shrink: 0;
    filter: grayscale(1) brightness(0.6);
    transition: filter 0.3s;
  }

  @media (prefers-reduced-motion: reduce) {
    .marquee-track {
      animation: none;
    }
  }
</style>
